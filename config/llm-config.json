{
  "primary_backend": "openrouter",
  "fallback_backend": "openrouter",
  "backends": {
    "local-ollama": {
      "type": "ollama",
      "endpoint": "http://localhost:11434",
      "model": "qwen2.5:14b",
      "timeout": 180,
      "cost_per_project": 0.0,
      "enabled": false
    },
    "remote-ollama": {
      "type": "ollama",
      "endpoint": "http://192.168.1.100:11434",
      "model": "qwen2.5:14b",
      "timeout": 180,
      "cost_per_project": 0.0,
      "enabled": false
    },
    "openai-mini": {
      "type": "openai",
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o-mini",
      "api_key_env": "OPENAI_API_KEY",
      "timeout": 180,
      "cost_per_project": 0.012,
      "enabled": false
    },
    "openai": {
      "type": "openai",
      "endpoint": "https://api.openai.com/v1/chat/completions",
      "model": "gpt-4o",
      "api_key_env": "OPENAI_API_KEY",
      "timeout": 180,
      "cost_per_project": 0.2,
      "enabled": false
    },
    "openrouter-claude": {
      "type": "openrouter",
      "endpoint": "https://openrouter.ai/api/v1/chat/completions",
      "model": "anthropic/claude-sonnet-4.5",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 240,
      "cost_per_project": 0.25
    },
    "gemini-flash": {
      "type": "gemini",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent",
      "model": "gemini-1.5-flash",
      "api_key_env": "GEMINI_API_KEY",
      "timeout": 180,
      "cost_per_project": 0.015
    },
    "gemini-flash-8b": {
      "type": "gemini",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash-8b:generateContent",
      "model": "gemini-1.5-flash-8b",
      "api_key_env": "GEMINI_API_KEY",
      "timeout": 180,
      "cost_per_project": 0.008
    },
    "gemini-pro": {
      "type": "gemini",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent",
      "model": "gemini-1.5-pro",
      "api_key_env": "GEMINI_API_KEY",
      "timeout": 240,
      "cost_per_project": 0.08
    },
    "openrouter": {
      "type": "openrouter",
      "endpoint": "https://openrouter.ai/api/v1/chat/completions",
      "fallback_model": "anthropic/claude-sonnet-4.6",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 180,
      "cost_per_project": 0.02
    },
    "openrouter-big-brain": {
      "type": "openrouter",
      "endpoint": "https://openrouter.ai/api/v1/chat/completions",
      "fallback_model": "anthropic/claude-opus-4.6",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 300,
      "cost_per_project": 0.1
    },
    "openrouter-cheapskate": {
      "type": "openrouter",
      "endpoint": "https://openrouter.ai/api/v1/chat/completions",
      "fallback_model": "anthropic/claude-haiku-4.5",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 300,
      "cost_per_project": 0.0,
      "enabled": true
    },
    "openrouter-direct": {
      "type": "openrouter",
      "endpoint": "https://openrouter.ai/api/v1/chat/completions",
      "api_key_env": "OPENROUTER_API_KEY",
      "timeout": 300
    },
    "local-dougie": {
      "type": "openai",
      "endpoint": "http://localhost:27180/v1/chat/completions",
      "endpoint_env": "DOUGIE_ENDPOINT",
      "model": "mlx-community/Qwen3.6-35B-A3B-4bit",
      "strip_reasoning": true,
      "force_model": true,
      "defer_when_unavailable": true,
      "max_tokens": 8192,
      "timeout": 300,
      "cost_per_project": 0.0,
      "enabled": false
    }
  },
  "auto_select": {
    "enabled": true,
    "preference_order": [
      "openrouter"
    ],
    "check_interval_seconds": 5
  },
  "processing": {
    "check_queue_interval_seconds": 300,
    "batch_size": 4,
    "parallel_processing": false
  },
  "worker": {
    "max_concurrent_jobs": 3,
    "poll_interval_seconds": 5,
    "heartbeat_interval_seconds": 60
  },
  "phase_backends": {
    "analyst": "openrouter-cheapskate",
    "formatter": "openrouter",
    "seo": "openrouter-cheapskate",
    "validator": "openrouter-cheapskate",
    "timestamp": "openrouter",
    "copy_editor": "openrouter-big-brain"
  },
  "routing": {
    "completeness": {
      "enabled": true,
      "coverage_threshold": 0.70,
      "min_source_words": 500,
      "pause_on_truncation": true
    },
    "seam_coverage": {
      "enabled": true,
      "min_run": 4,
      "per_caption_floor": 0.5,
      "pause_on_gap": true
    },
    "speaker_segmentation": {
      "enabled": true
    },
    "chunking": {
      "enabled": true,
      "threshold_words": 3000,
      "target_chunk_words": 2000,
      "overlap_captions": 8,
      "max_parallel": 3,
      "min_tier": 1
    },
    "deferral": {
      "backoff_minutes": [2, 5, 10, 15],
      "ceiling_hours": 6
    }
  },
  "model_families": [
    {
      "name": "Claude Haiku",
      "provider": "Anthropic",
      "tier": 0,
      "patterns": ["anthropic/claude-haiku-*"]
    },
    {
