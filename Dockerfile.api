FROM python:3.13-slim

ENV PYTHONUNBUFFERED=1

WORKDIR /app

# ffmpeg: audio-track extraction for media uploads (audio upload mode)
RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg && rm -rf /var/lib/apt/lists/*

# Install dependencies first for better layer caching
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY api/ api/
COPY config/ config/
COPY mcp_server/ mcp_server/
# Copy LLM phase prompts (system prompts for analyst, formatter, seo, validator, timestamp, copy_editor)
COPY prompts/ prompts/
COPY knowledge/ knowledge/
COPY alembic.ini* ./
COPY alembic/ alembic/
COPY scripts/ scripts/
COPY pyproject.toml* ./
COPY run_worker.py .
COPY entrypoint.sh .
RUN chmod +x entrypoint.sh

# Resolve __version__ at build time. Image builds don't have access to .git,
# so CI passes the version computed from `git describe` as a build arg. The
# pretend-version env var makes setuptools_scm write api/_version.py during
# `pip install -e .`. See docs/VERSIONING.md.
ARG SETUPTOOLS_SCM_PRETEND_VERSION_FOR_EDITORIAL_ASSISTANT=0.0.0+unknown
ENV SETUPTOOLS_SCM_PRETEND_VERSION_FOR_EDITORIAL_ASSISTANT=${SETUPTOOLS_SCM_PRETEND_VERSION_FOR_EDITORIAL_ASSISTANT}
RUN pip install -e . --no-deps

# Create writable directories before switching to non-root user
RUN mkdir -p logs /data/db /data/output /data/transcripts /data/media

# Run as non-root user for security
RUN useradd --create-home appuser && chown -R appuser:appuser logs config /data
USER appuser

ENTRYPOINT ["./entrypoint.sh"]

# No EXPOSE or HEALTHCHECK here: this image runs both the api (port 8000)
# and the mcp server (port 8080) depending on which compose service uses it.
# Each compose service declares its own ports and healthcheck.

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
